<UserControl x:Class="cchay_optimicer_cs.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:cchay_optimicer_cs.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Configuración General" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
                <TextBlock Text="Personaliza el comportamiento en segundo plano, la bandeja de sistema y tareas automatizadas." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Message Toast -->
            <TextBlock x:Name="TxtMessage" Visibility="Collapsed" Text="" Padding="12" FontSize="13" FontWeight="Medium" Background="#1A107C41" Foreground="#40C057" Margin="0,0,0,20" HorizontalAlignment="Stretch" TextAlignment="Center" />

            <!-- System Tray Card -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="Glance24" FontSize="20" Foreground="{DynamicResource AccentTextWritableBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="Minimizar a la Bandeja del Sistema" FontSize="14.5" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="Cuando se minimiza o cierra la ventana principal, el optimizador continuará ejecutándose de forma invisible en la bandeja de sistema (System Tray)." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    
                    <ui:ToggleSwitch x:Name="ToggleMinimizeTray" Grid.Column="1" VerticalAlignment="Center" Checked="ToggleMinimizeTray_Changed" Unchecked="ToggleMinimizeTray_Changed" />
                </Grid>
            </ui:Card>

            <!-- Auto RAM Card -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="20" Foreground="#40C057" Margin="0,0,8,0" />
                                <TextBlock Text="Limpieza Automática de Memoria RAM" FontSize="14.5" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="Ejecuta de manera silenciosa una limpieza total de memoria cada 2 minutos si el consumo actual supera el umbral configurado." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <ui:ToggleSwitch x:Name="ToggleAutoRam" Grid.Column="1" VerticalAlignment="Center" Checked="ToggleAutoRam_Changed" Unchecked="ToggleAutoRam_Changed" />
                    </Grid>
                    
                    <StackPanel x:Name="PanelRamThreshold" Orientation="Horizontal" Margin="28,10,0,0" Visibility="Collapsed">
                        <TextBlock Text="Umbral de Activación de RAM:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12.5" />
                        <ComboBox x:Name="ComboRamThreshold" Width="100" SelectionChanged="ComboRamThreshold_SelectionChanged">
                            <ComboBoxItem Content="70%" Tag="70" />
                            <ComboBoxItem Content="75%" Tag="75" />
                            <ComboBoxItem Content="80%" Tag="80" />
                            <ComboBoxItem Content="85%" Tag="85" />
                            <ComboBoxItem Content="90%" Tag="90" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Daily Scheduled Maintenance Card -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="Flash24" FontSize="20" Foreground="#FD7E14" Margin="0,0,8,0" />
                                <TextBlock Text="Mantenimiento Diario Automático" FontSize="14.5" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="Programa una optimización completa en segundo plano (Modo Técnico) a una hora específica del día para mantener el sistema óptimo de forma permanente." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <ui:ToggleSwitch x:Name="ToggleDailyMaintenance" Grid.Column="1" VerticalAlignment="Center" Checked="ToggleDailyMaintenance_Changed" Unchecked="ToggleDailyMaintenance_Changed" />
                    </Grid>
                    
                    <StackPanel x:Name="PanelDailyTime" Orientation="Horizontal" Margin="28,10,0,0" Visibility="Collapsed">
                        <TextBlock Text="Hora de Mantenimiento (HH:mm):" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12.5" />
                        <ComboBox x:Name="ComboDailyTime" Width="120" SelectionChanged="ComboDailyTime_SelectionChanged">
                            <ComboBoxItem Content="00:00" Tag="00:00" />
                            <ComboBoxItem Content="01:00" Tag="01:00" />
                            <ComboBoxItem Content="02:00" Tag="02:00" />
                            <ComboBoxItem Content="03:00" Tag="03:00" />
                            <ComboBoxItem Content="04:00" Tag="04:00" />
                            <ComboBoxItem Content="05:00" Tag="05:00" />
                            <ComboBoxItem Content="12:00" Tag="12:00" />
                            <ComboBoxItem Content="18:00" Tag="18:00" />
                            <ComboBoxItem Content="22:00" Tag="22:00" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Auto Restore Point Card -->
            <ui:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="20" Foreground="#1098AD" Margin="0,0,8,0" />
                            <TextBlock Text="Punto de Restauración Pre-Optimización" FontSize="14.5" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="Crea automáticamente un Punto de Restauración del Sistema antes de aplicar optimizaciones rápidas, técnicas o tweaks de registro." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    
                    <ui:ToggleSwitch x:Name="ToggleAutoRestore" Grid.Column="1" VerticalAlignment="Center" Checked="ToggleAutoRestore_Changed" Unchecked="ToggleAutoRestore_Changed" />
                </Grid>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
