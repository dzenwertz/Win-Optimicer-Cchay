<UserControl x:Class="cchay_optimicer_cs.Views.SoftwarePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:cchay_optimicer_cs.Views"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Instalador de Software Esencial" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
                <TextBlock Text="Instala de forma masiva y silenciosa aplicaciones gratuitas usando Windows Package Manager (winget)." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Status Alert -->
            <ui:Card Padding="12" BorderBrush="{DynamicResource AccentBorderThemeBrush}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Info24" FontSize="24" Foreground="{DynamicResource AccentTextWritableBrush}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center">
                        <Run FontWeight="Bold" Text="Nota:" /> Las instalaciones se realizan en segundo plano de forma silenciosa. Asegúrate de tener conexión a Internet activa y no cerrar el programa durante el proceso.
                    </TextBlock>
                </Grid>
            </ui:Card>

            <!-- Action panel -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button x:Name="BtnSelectAll" Content="Seleccionar Todo" Appearance="Secondary" Click="BtnSelectAll_Click" Margin="0,0,8,0" />
                    <ui:Button x:Name="BtnDeselectAll" Content="Deseleccionar Todo" Appearance="Secondary" Click="BtnDeselectAll_Click" />
                </StackPanel>

                <ui:Button x:Name="BtnInstall" Grid.Column="1" Appearance="Primary" Padding="28,12,28,12" Click="BtnInstall_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,8,0" />
                        <TextBlock x:Name="TxtInstallBtn" Text="Instalar Seleccionados" FontWeight="SemiBold" />
                    </StackPanel>
                </ui:Button>
            </Grid>

            <!-- Installation Progress Card (Hidden by default) -->
            <ui:Card x:Name="CardProgress" Padding="16" Margin="0,0,0,20" Visibility="Collapsed" BorderBrush="#1098AD">
                <StackPanel>
                    <TextBlock x:Name="TxtProgressStatus" Text="Instalando programas..." FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ProgressBar x:Name="ProgInstall" Height="6" Minimum="0" Maximum="100" Value="0" Foreground="#1098AD" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,0,8" />
                    <TextBlock x:Name="TxtCurrentApp" Text="Iniciando..." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </ui:Card>

            <!-- Logs / Terminal Output Card (Hidden by default) -->
            <ui:Card x:Name="CardLogs" Padding="14" Margin="0,0,0,20" Visibility="Collapsed" Background="#0C0C0C" BorderBrush="#2A2A2A">
                <StackPanel>
                    <TextBlock Text="Registro de Instalación (Consola)" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,6" />
                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto" x:Name="LogScroll">
                        <TextBox x:Name="TxtConsoleLog" 
                                 FontFamily="Consolas" 
                                 FontSize="11" 
                                 Foreground="#4AF626" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 IsReadOnly="True" 
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </StackPanel>
            </ui:Card>

            <!-- Software list by category -->
            <ItemsControl x:Name="ListSoftware">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" />

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,8,0" />
                                        <Border CornerRadius="4" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="6,2,6,2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="2" CornerRadius="4" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8,4,8,4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding StatusColor}" />
                                </Border>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
