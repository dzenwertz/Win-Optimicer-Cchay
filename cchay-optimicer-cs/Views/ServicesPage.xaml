<UserControl x:Class="cchay_optimicer_cs.Views.ServicesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:cchay_optimicer_cs.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Servicios de Windows" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="Detén o deshabilita servicios redundantes de segundo plano para mejorar la velocidad y liberar memoria RAM." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Row 1: Optimization Profiles -->
        <Border Grid.Row="1" CornerRadius="8" BorderThickness="1" BorderBrush="#2A2D35" Background="#0AFFFFFF" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ui:SymbolIcon Symbol="Rocket24" FontSize="18" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,8,0" />
                    <TextBlock Text="Perfiles de Optimización" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Selecciona un perfil para optimizar automáticamente los servicios de Windows según tu caso de uso." FontSize="12.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Recommended Profile -->
                    <Border Grid.Column="0" x:Name="CardRecommended" CornerRadius="8" BorderThickness="1" BorderBrush="#2A3A2D" Background="#0A40C057" Padding="14" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonUp="Profile_Click" Tag="recommended">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="🛡️" FontSize="18" Margin="0,0,6,0" />
                                <TextBlock Text="Recomendado" FontSize="14" FontWeight="Bold" Foreground="#40C057" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Seguro para todos. Desactiva telemetría, diagnósticos y servicios obsoletos." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="4" Padding="6,2,6,2" Background="#1A40C057">
                                    <TextBlock x:Name="TxtRecommendedCount" Text="— servicios" FontSize="10" Foreground="#40C057" FontWeight="Medium" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Gaming Profile -->
                    <Border Grid.Column="1" x:Name="CardGaming" CornerRadius="8" BorderThickness="1" BorderBrush="#2D2A3A" Background="#0A7C3AED" Padding="14" Margin="3,0,3,0" Cursor="Hand" MouseLeftButtonUp="Profile_Click" Tag="gaming">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="🎮" FontSize="18" Margin="0,0,6,0" />
                                <TextBlock Text="Gaming" FontSize="14" FontWeight="Bold" Foreground="#7C3AED" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Desactiva Xbox, Bluetooth, indexación, Superfetch y todo lo que robe FPS." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="4" Padding="6,2,6,2" Background="#1A7C3AED">
                                    <TextBlock x:Name="TxtGamingCount" Text="— servicios" FontSize="10" Foreground="#7C3AED" FontWeight="Medium" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Maximum Profile -->
                    <Border Grid.Column="2" x:Name="CardMaximum" CornerRadius="8" BorderThickness="1" BorderBrush="#3A2A2D" Background="#0AFA5252" Padding="14" Margin="6,0,0,0" Cursor="Hand" MouseLeftButtonUp="Profile_Click" Tag="maximum">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="⚡" FontSize="18" Margin="0,0,6,0" />
                                <TextBlock Text="Máximo Rendimiento" FontSize="14" FontWeight="Bold" Foreground="#FA5252" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Agresivo. P2P, geolocalización, UPnP, biometría, escritorio remoto y más." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="4" Padding="6,2,6,2" Background="#1AFA5252">
                                    <TextBlock x:Name="TxtMaximumCount" Text="— servicios" FontSize="10" Foreground="#FA5252" FontWeight="Medium" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Progress bar for profile application -->
                <StackPanel x:Name="PanelProfileProgress" Visibility="Collapsed" Margin="0,12,0,0">
                    <TextBlock x:Name="TxtProfileProgress" Text="Aplicando perfil..." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                    <ProgressBar x:Name="ProgProfile" Minimum="0" Maximum="100" Value="0" Height="6" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Actions, Search & Filters -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="TxtSearch" PlaceholderText="Buscar servicios por nombre o descripción..." Icon="Search24" TextChanged="TxtSearch_TextChanged" />
                <ui:Button Grid.Column="1" x:Name="BtnOptimizeAll" Margin="10,0,0,0" Content="Optimizar Recomendados" Icon="Wrench24" Click="BtnOptimizeAll_Click" Appearance="Primary" />
            </Grid>

            <!-- Category/Filter tabs -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <RadioButton x:Name="RadAll" Content="Todos" IsChecked="True" Checked="Filter_Checked" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,6,12,6" Margin="0,0,8,0" />
                <RadioButton x:Name="RadRunning" Content="En Ejecución" Checked="Filter_Checked" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,6,12,6" Margin="0,0,8,0" />
                <RadioButton x:Name="RadStopped" Content="Detenidos" Checked="Filter_Checked" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,6,12,6" Margin="0,0,8,0" />
                <RadioButton x:Name="RadDisabled" Content="Deshabilitados" Checked="Filter_Checked" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,6,12,6" Margin="0,0,8,0" />
                <RadioButton x:Name="RadBloat" Content="Optimizables" Checked="Filter_Checked" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,6,12,6" />
            </StackPanel>
        </StackPanel>

        <!-- Row 3: Result message -->
        <TextBlock Grid.Row="3" x:Name="TxtResult" FontSize="13" FontWeight="Medium" Foreground="#40C057" Visibility="Collapsed" Margin="0,0,0,10" TextWrapping="Wrap" />

        <!-- Row 4: List View -->
        <ListView Grid.Row="4" x:Name="ListServices" ScrollViewer.HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ui:Card Padding="12" Margin="0,0,0,6" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Name, StringFormat='({0})'}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />

                                    <Border CornerRadius="4" Padding="6,2,6,2" VerticalAlignment="Center" Margin="0,0,4,0" Background="{Binding RiskBadgeBg}">
                                        <TextBlock Text="{Binding RiskBadgeText}" FontSize="9" FontWeight="Bold" Foreground="{Binding RiskBadgeFg}" />
                                    </Border>

                                    <Border CornerRadius="4" Padding="6,2,6,2" VerticalAlignment="Center" Background="{Binding StartupTypeBadgeBg}">
                                        <TextBlock Text="{Binding StartupType}" FontSize="9" Foreground="{Binding StartupTypeBadgeFg}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Control Actions -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Status Label -->
                                <Border CornerRadius="4" Padding="8,4,8,4" Margin="0,0,10,0" VerticalAlignment="Center" Background="{Binding StatusBadgeBg}">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Medium" Foreground="{Binding StatusBadgeFg}" />
                                </Border>

                                <!-- Combobox for Startup Type -->
                                <ComboBox Margin="0,0,6,0" Width="120" SelectedValue="{Binding StartupType, Mode=TwoWay}" SelectedValuePath="Content" SelectionChanged="StartupType_SelectionChanged" IsEnabled="{Binding IsConfigurable}" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Automático" />
                                    <ComboBoxItem Content="Manual" />
                                    <ComboBoxItem Content="Deshabilitado" />
                                </ComboBox>

                                <!-- Stop/Start Action -->
                                <ui:Button Content="{Binding ActionButtonText}" 
                                        Click="BtnServiceAction_Click" 
                                        IsEnabled="{Binding IsConfigurable}"
                                        Width="70" 
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </ui:Card>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
