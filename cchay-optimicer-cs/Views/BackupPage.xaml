<UserControl x:Class="cchay_optimicer_cs.Views.BackupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:cchay_optimicer_cs.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Backup y Restauración" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
                <TextBlock Text="Crea copias de seguridad y puntos de restauración antes de optimizar el sistema." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Toast Messages -->
            <TextBlock x:Name="TxtMessage" Visibility="Collapsed" Text="" Padding="12" FontSize="13" FontWeight="Medium" Background="#1A107C41" Foreground="#40C057" Margin="0,0,0,20" HorizontalAlignment="Stretch" TextAlignment="Center" />

            <!-- Safety Notice Card -->
            <ui:Card Padding="14" BorderBrush="{DynamicResource AccentBorderThemeBrush}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="32" Foreground="{DynamicResource AccentTextWritableBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Puntos de Restauración del Sistema" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Un punto de restauración guarda el estado del registro y de los archivos críticos de Windows. Si alguna optimización causa problemas, puedes restablecer tu PC a un estado anterior de forma segura." FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <ui:ToggleSwitch Grid.Column="2" x:Name="ToggleAutoRestore" Content="Crear punto automático antes de cambios" VerticalAlignment="Center" Checked="ToggleAutoRestore_Changed" Unchecked="ToggleAutoRestore_Changed" />
                </Grid>
            </ui:Card>

            <UniformGrid Columns="2" Rows="1" Margin="0,0,0,20">
                <!-- Create Backup Card -->
                <ui:Card Margin="0,0,6,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="Add24" FontSize="18" Foreground="{DynamicResource AccentTextWritableBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="Crear Punto de Restauración" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                        
                        <ui:TextBox x:Name="TxtBackupName" PlaceholderText="Nombre del punto (ej. AntesDeTweaks)" Margin="0,0,0,10" />
                        
                        <ui:Button x:Name="BtnCreateBackup" Appearance="Primary" Content="Crear Punto de Restauración" HorizontalAlignment="Stretch" Click="BtnCreateBackup_Click" />
                    </StackPanel>
                </ui:Card>

                <!-- System Utilities Card -->
                <ui:Card Margin="6,0,0,0" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <ui:SymbolIcon Symbol="OpenFolder24" FontSize="18" Foreground="{DynamicResource AccentTextWritableBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="Utilidades del Sistema" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="Puedes abrir la restauración del sistema nativa de Windows (rstrui) para revertir cambios." FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1">
                            <ui:Button Appearance="Secondary" Content="Abrir Restauración de Sistema (rstrui)" HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="BtnOpenRestoreUI_Click" />
                            
                            <!-- Delete button -->
                            <ui:Button x:Name="BtnDeleteAll" Appearance="Secondary" Content="Eliminar Todos los Puntos (Liberar Espacio)" HorizontalAlignment="Stretch" Foreground="#FA5252" BorderBrush="#22FA5252" Click="BtnDeleteAll_Click" />
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </UniformGrid>

            <!-- Restore Points List Title -->
            <TextBlock Text="Puntos de Restauración Disponibles" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,10,0,10" />

            <!-- ListView Table -->
            <ListView x:Name="ListPoints" MinHeight="150" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID (Secuencia)" Width="100" DisplayMemberBinding="{Binding SequenceNumber}" />
                        <GridViewColumn Header="Descripción" Width="300" DisplayMemberBinding="{Binding Description}" />
                        <GridViewColumn Header="Fecha de Creación" Width="200" DisplayMemberBinding="{Binding CreationTime}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</UserControl>
