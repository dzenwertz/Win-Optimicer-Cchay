<UserControl x:Class="cchay_optimicer_cs.Views.NetworkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:cchay_optimicer_cs.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Optimizador de Red" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
                <TextBlock Text="Optimiza la latencia de internet configurando servidores DNS rápidos y aplicando optimizaciones TCP." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Message Toast -->
            <TextBlock x:Name="TxtMessage" Visibility="Collapsed" Text="" Padding="12" FontSize="13" FontWeight="Medium" Background="#1A107C41" Foreground="#40C057" Margin="0,0,0,20" HorizontalAlignment="Stretch" TextAlignment="Center" />

            <!-- TCP Tweaks Card -->
            <ui:Card Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <ui:SymbolIcon Symbol="Pulse24" FontSize="20" Foreground="{DynamicResource AccentTextWritableBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="Optimización TCP de Alto Rendimiento" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="Ajusta la pila de red TCP de Windows (RSS, Autotuning, ecncapability) para acelerar descargas y reducir ping." FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    
                    <ui:ToggleSwitch x:Name="ToggleTcp" Grid.Column="1" VerticalAlignment="Center" Checked="ToggleTcp_Changed" Unchecked="ToggleTcp_Changed" />
                </Grid>
            </ui:Card>

            <!-- Internet Speed Test Card -->
            <TextBlock Text="Prueba de Velocidad de Internet" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,10" />
            <ui:Card Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Circular progress ring with needle/number -->
                    <Grid Width="130" Height="130" Margin="0,0,24,0">
                        <Ellipse Stroke="{DynamicResource ControlFillColorDefaultBrush}" StrokeThickness="8" />
                        <ui:ProgressRing x:Name="ProgSpeedTest" Progress="0" Width="130" Height="130" Foreground="#1098AD" />
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtSpeedValue" Text="0.0" FontSize="26" FontWeight="Bold" Foreground="#1098AD" HorizontalAlignment="Center" />
                            <TextBlock Text="Mbps" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Right: Info & Button -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Medidor de Ancho de Banda y Ping" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Text="Mide la latencia y la velocidad real de descarga de tu conexión a internet para validar el impacto de las optimizaciones." FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Ping -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ping (Latencia)" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock x:Name="TxtSpeedPing" Text="-- ms" FontSize="15" FontWeight="SemiBold" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Descarga -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Descarga" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock x:Name="TxtSpeedDownload" Text="-- Mbps" FontSize="15" FontWeight="SemiBold" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Estado -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Estado" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock x:Name="TxtSpeedStatus" Text="Listo" FontSize="14" FontWeight="SemiBold" Foreground="#1098AD" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <ui:Button x:Name="BtnRunSpeedTest" Content="Iniciar Prueba de Velocidad" Appearance="Primary" Padding="20,10,20,10" HorizontalAlignment="Left" Click="BtnRunSpeedTest_Click" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Diagnostics Title -->
            <TextBlock Text="Herramientas de Diagnóstico" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,10" />

            <!-- Tools grid -->
            <UniformGrid Columns="3" Rows="1" Height="42" Margin="0,0,0,20">
                <ui:Button x:Name="BtnPingTest" Margin="0,0,6,0" Appearance="Secondary" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BtnPingTest_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Pulse24" Margin="0,0,6,0" />
                        <TextBlock x:Name="TxtPingBtn" Text="Test de Velocidad DNS" />
                    </StackPanel>
                </ui:Button>

                <ui:Button x:Name="BtnFlushDns" Margin="3,0,3,0" Appearance="Secondary" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BtnFlushDns_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Delete24" Margin="0,0,6,0" />
                        <TextBlock x:Name="TxtFlushBtn" Text="Vaciar Caché (Flush)" />
                    </StackPanel>
                </ui:Button>

                <ui:Button x:Name="BtnResetDns" Margin="6,0,0,0" Appearance="Secondary" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="#FA5252" BorderBrush="#22FA5252" Click="BtnResetDns_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowCounterclockwise24" Margin="0,0,6,0" />
                        <TextBlock x:Name="TxtResetBtn" Text="Restablecer (DHCP)" />
                    </StackPanel>
                </ui:Button>
            </UniformGrid>

            <!-- DNS Servers Title -->
            <TextBlock Text="Servidores DNS Disponibles" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,10,0,10" />

            <!-- DNS List -->
            <ItemsControl x:Name="ListDNS">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,8,0" />
                                        <Border CornerRadius="4" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="6,2,6,2" Visibility="{Binding PingVisibility}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PingText}" FontSize="10" FontWeight="Bold" Foreground="{Binding PingColor}" />
                                        </Border>
                                    </StackPanel>
                                    
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,4">
                                        <Run Text="IPs: " />
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding Primary, Mode=OneWay}" />
                                        <Run Text="  —  " />
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding Secondary, Mode=OneWay}" />
                                    </TextBlock>
                                    
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <ui:Button Grid.Column="1" 
                                           Appearance="Primary" 
                                           Content="{Binding StatusText}" 
                                           VerticalAlignment="Center" 
                                           Padding="16,8,16,8"
                                           Tag="{Binding Key}"
                                           Click="BtnApplyDns_Click" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
